{
  "name": "solo-mine",
  "version": "1.0.0",
  "description": "The complete educational platform for Bitcoin home mining",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "predeploy": "node scripts/pre-deploy-check.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:links": "blc http://localhost:3000 -ro",
    "setup:admin": "node scripts/setup-admin.js",
    "postinstall": "npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@react-three/drei": "^9.96.0",
    "@react-three/fiber": "^8.15.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.312.0",
    "next": "14.1.0",
    "next-themes": "^0.2.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-spring": "^9.7.3",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.4.17",
    "broken-link-checker": "^0.7.8",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "simple-git-hooks": "^2.9.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "bitcoin",
    "mining",
    "education",
    "nextjs",
    "react"
  ],
  "author": "Solo Mine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/solo-mine.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/solo-mine/issues"
  },
  "homepage": "https://solomine.io"
}
