# =============================================================================
# Solo Mine - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git (it's in .gitignore)
# =============================================================================

# =============================================================================
# Admin Authentication (Required)
# =============================================================================

# Generate a secure random string (64+ characters recommended)
# You can use: openssl rand -hex 32
ADMIN_TOKEN=your_secure_random_token_here_min_32_chars

# Generate password hash using the admin setup script
# ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
# PASSWORD_SALT=your_salt_here

# =============================================================================
# Analytics (Recommended)
# =============================================================================

# Plausible Analytics (Privacy-friendly, recommended)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=solomine.io
# PLAUSIBLE_API_KEY=optional_for_admin_dashboard

# Google Analytics (Optional - only if you prefer GA over Plausible)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =============================================================================
# Email Service (Choose ONE - either ConvertKit OR Resend/Supabase)
# =============================================================================

# Option A: ConvertKit (Easier, hosted solution)
# Get from: https://convertkit.com
# CONVERTKIT_API_KEY=your_convertkit_api_key
# CONVERTKIT_API_SECRET=your_convertkit_secret
# CONVERTKIT_FORM_ID=your_form_id

# Option B: Resend + Supabase (More control, self-hosted)
# Get from: https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@solomine.io
RESEND_REPLY_TO=support@solomine.io

# =============================================================================
# Database (Required if using Resend option above)
# =============================================================================

# Get from: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =============================================================================
# Bitcoin Data APIs (Optional - free tiers work fine)
# =============================================================================

# CoinGecko (free tier has rate limits, pro key optional)
# COINGECKO_API_KEY=optional_premium_key

# Mempool.space (no key required for free tier)
MEMPOOL_SPACE_API_URL=https://mempool.space/api

# =============================================================================
# Site Configuration (Required)
# =============================================================================

NEXT_PUBLIC_SITE_URL=https://solomine.io
NEXT_PUBLIC_SITE_NAME=Solo Mine
NEXT_PUBLIC_SITE_DESCRIPTION="Learn if Bitcoin mining is right for you"

# Google Search Console verification (optional)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your_verification_code

# =============================================================================
# Affiliate Links (Required - Update with your actual affiliate URLs)
# =============================================================================

# Example - replace with real affiliate program URLs
AFFILIATE_BITAXE=https://example.com/affiliate/bitaxe
AFFILIATE_NERDQAXE=https://example.com/affiliate/nerdqaxe
AFFILIATE_AVALON=https://example.com/affiliate/avalon

# =============================================================================
# Social Links (Optional)
# =============================================================================

NEXT_PUBLIC_TWITTER_HANDLE=@solomine
NEXT_PUBLIC_GITHUB_REPO=https://github.com/yourusername/solo-mine
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/solomine

# =============================================================================
# Monitoring (Optional but recommended)
# =============================================================================

# Sentry for error tracking
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production

# LogRocket for session replay
# LOGROCKET_APP_ID=xxxx/xxxx

# =============================================================================
# Feature Flags (Optional)
# =============================================================================

# Enable experimental/beta features
NEXT_PUBLIC_ENABLE_EXPERIMENTAL=false

# Enable debug mode (only in development)
NEXT_PUBLIC_DEBUG=false

# Enable verbose API logging
DEBUG_API=false

# Skip admin auth in development (DANGEROUS - never in production!)
# SKIP_ADMIN_AUTH=false

# =============================================================================
# NOTES
# =============================================================================

# 1. NEVER commit this file with real values to git
# 2. In Vercel dashboard, add these as Environment Variables
# 3. For local development, copy this to .env.local and fill values
# 4. To generate admin credentials, run: npm run setup:admin

# =============================================================================
